        "jsCode": "const lines = [];\nconst menuText = \"🍔 *Our Menu* 🍕\\n\";\n\nlet i = 1;\n\nfor (const item of $input.all()) {\n  const name = item.json['Product Name'];\n  const price = item.json['Price'];\n\n  lines.push(`${i}️⃣ ${name} — ${price} EGP`);\n  i++;\n}\n\nconst tasksText = menuText + \"\\n\" + lines.join(\"\\n\");\n\nreturn [{ json: { tasksText } }];"
